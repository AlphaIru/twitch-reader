# RENAME THIS FILE TO .env

# Note: This is your twitch id not your bot's id
TWITCH_CLIENT_ID=your_client_id

# Note: do not put "oauth://" or "https://"
TWITCH_CLIENT_SECRET=your_client_secret

# Note: This is where your bot get its dic
OPEN_JTALK_DICT_PATH=/usr/share/open-jtalk/dic

# Note: This is where your bot locate its voice
OPEN_JTALK_VOICE_PATH=/usr/share/open-jtalk/voices/nitech_jp_atr503_m001.htsvoice

# Note: This is the max character count of the message
MAX_CHAR_COUNT=100

# Note: This is the max queue count
MAX_QUEUE_COUNT=100
