use std::env;
use std::error::Error;

use serde::{Deserialize, Serialize};

use tiny_http::{Response, Server};

use url::Url;


#[derive(Clone, Debug, Deserialize, Serialize)]
pub struct Config {
    pub username: String,
    pub token: String,
    pub refresh_token: Option<String>,
}

impl Default for Config {
    fn default() -> Self {
        Self {
            username: "".into(),
            token: "".into(),
            refresh_token: None,
        }
    }
}


pub fn get_valid_config() -> Config {
    let app_name = "twitch_reader";

    loop {
        let config = Config::from_file(app_name);
        
        if config.is_valid() {
            return config;
        }
    }
}

